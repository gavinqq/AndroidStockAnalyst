<resources>
    <style name="Theme.AutoStockPlan" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/app_orange</item>
        <item name="colorPrimaryVariant">@color/app_orange_dark</item>
        <item name="colorOnPrimary">@color/app_text</item>
        <item name="colorSecondary">@color/app_yellow</item>
        <item name="colorSecondaryVariant">@color/app_orange</item>
        <item name="colorOnSecondary">@color/app_text</item>
        <item name="android:colorAccent">@color/app_orange</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:textColorPrimary">@color/app_text</item>
        <item name="android:textColorSecondary">@color/app_text_muted</item>
        <item name="android:statusBarColor">@color/app_orange</item>
        <item name="textInputStyle">@style/Widget.AutoStockPlan.TextInputLayout</item>
        <item name="materialButtonStyle">@style/Widget.AutoStockPlan.Button</item>
    </style>

    <style name="Widget.AutoStockPlan.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/app_orange</item>
        <item name="android:textColor">@color/app_text</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.AutoStockPlan.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/app_surface</item>
        <item name="boxStrokeColor">@color/app_orange</item>
        <item name="hintTextColor">@color/app_text_muted</item>
        <item name="helperTextTextColor">@color/app_text_muted</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>
    
    <style name="Theme.AutoStockPlan.AppBarOverlay" parent="ThemeOverlay.AppCompat.Light" />
    <style name="Theme.AutoStockPlan.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
